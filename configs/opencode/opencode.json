{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "yolo": {
      "description": "Full-permission primary agent, skips all approval prompts",
      "mode": "primary",
      "color": "error",
      "permission": {
        "*": "allow",
        "bash": {
          "*": "allow",
          "rm -rf /": "deny",
          "rm -rf ~": "deny",
          "rm -rf /*": "deny",
          "rm -rf ~/*": "deny",
          "rm -rf *": "deny"
        }
      }
    }
  }
}
